# Homeserver Admin API Configuration
# These are server-only environment variables (not exposed to the client)
# For local development, copy this file to .env.local and update the values

# Homeserver admin endpoint base URL
# Example: http://localhost:6288 (for local development)
# Example: http://homeserver:6288 (for Docker/Umbrel - service name)
ADMIN_BASE_URL=http://localhost:6288

# Admin password/token for authentication
ADMIN_TOKEN=your-admin-password-here

# Path to homeserver config.toml (read-only display in Settings)
# Default: /app/homeserver-data/config.toml (Docker/Umbrel)
# For non-Docker: set to wherever your homeserver stores config.toml
# HOMESERVER_CONFIG_PATH=/home/user/.pubky/data/config.toml